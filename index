    <!-- INTERACTIVE JAVASCRIPT LOGIC -->
    <script>
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide');
        const totalSlides = slides.length;
        
        // Mettre à jour les totaux statiques
        document.getElementById('total-slides').innerText = totalSlides;

        // Générer les indicateurs de navigation (points sous forme de tirets compacts)
        const dotsContainer = document.getElementById('dots-container');
        for (let i = 0; i < totalSlides; i++) {
            const dot = document.createElement('div');
            dot.className = `h-1.5 rounded-full transition-all duration-300 ${i === 0 ? 'w-8 bg-androLime' : 'w-3 bg-gray-700'}`;
            dot.id = `dot-${i}`;
            dotsContainer.appendChild(dot);
        }

        function changeSlide(direction) {
            // Cacher la slide courante
            slides[currentSlide].classList.remove('active');
            
            // Mettre à jour l'index
            currentSlide += direction;
            
            // Sécurité des limites
            if (currentSlide < 0) currentSlide = 0;
            if (currentSlide >= totalSlides) currentSlide = totalSlides - 1;

            // Afficher la nouvelle slide
            slides[currentSlide].classList.add('active');

            // Mettre à jour l'interface utilisateur globale
            document.getElementById('current-index').innerText = currentSlide + 1;
            
            // Mettre à jour la barre de progression supérieure
            const progressPercent = ((currentSlide + 1) / totalSlides) * 100;
            document.getElementById('progress').style.width = `${progressPercent}%`;

            // Mettre à jour l'état des boutons de contrôle inférieurs
            document.getElementById('prev-btn').disabled = currentSlide === 0;
            if (currentSlide === totalSlides - 1) {
                document.getElementById('next-btn').innerHTML = '<span>Terminer</span> <i class="fa-solid fa-circle-check"></i>';
            } else {
                document.getElementById('next-btn').innerHTML = '<span>Suivant</span> <i class="fa-solid fa-arrow-right"></i>';
            }

            // Gérer l'animation visuelle des points indicateurs inférieurs
            for (let i = 0; i < totalSlides; i++) {
                const dot = document.getElementById(`dot-${i}`);
                if (i === currentSlide) {
                    dot.className = 'h-1.5 w-8 bg-androLime rounded-full transition-all duration-300';
                } else {
                    dot.className = 'h-1.5 w-3 bg-gray-700 rounded-full transition-all duration-300';
                }
            }
        }

        // Support complet de la navigation par flèches du clavier pour les présentations sur projecteur
        document.addEventListener('keydown', function(event) {
            if (event.key === 'ArrowRight' || event.key === ' ') {
                if (currentSlide < totalSlides - 1) changeSlide(1);
            } else if (event.key === 'ArrowLeft') {
                if (currentSlide > 0) changeSlide(-1);
            }
        });
    </script>
